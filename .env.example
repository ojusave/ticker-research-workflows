# Copy to .env in repo root for local dev (server loads this via dotenv).
# On Render, set these on the web service; the workflow service also needs EXA_API_KEY.

# Claude synthesis (web service)
ANTHROPIC_API_KEY=

# Exa parallel search (workflow service: searchOne task)
EXA_API_KEY=

# Dispatch workflow tasks from the web service
# https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=

# Workflow service slug (default: ticker-research-workflows)
WORKFLOW_SERVICE_SLUG=ticker-research-workflows
